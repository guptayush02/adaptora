# =============================================================================
# Adaptora — frontend environment variables
# Copy this file to `.env` (or `.env.local`) and customize.
#
# IMPORTANT: Vite only exposes variables prefixed with VITE_ to client code.
# Anything in here is bundled into the production build and visible to users —
# do NOT put secrets here.
# =============================================================================

# Backend API base URL. Leave unset to use the Vite dev-server proxy in
# vite.config.js. Set this when the frontend is deployed separately from the
# backend (e.g. https://api.example.com).
VITE_API_URL=http://localhost:8000

# Branding (optional)
VITE_APP_NAME=Adaptora

# Defaults for the chat composer
VITE_DEFAULT_TEMPERATURE=0.7
VITE_DEFAULT_MODEL=auto
