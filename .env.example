# =============================================================================
# Adaptora — backend environment variables
# Copy this file to `.env` and customize. All values shown are defaults.
# =============================================================================

# ---- App metadata ----
APP_NAME=Adaptora
APP_VERSION=1.0.0
DEBUG=false

# ---- HTTP server (uvicorn) ----
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed origins, or a JSON array, or "*".
# Browsers reject credentialed requests when "*" is used — set explicit origins
# in production (e.g. http://localhost:5173,https://app.example.com).
CORS_ALLOW_ORIGINS=*

# ---- Auth / JWT ----
# CHANGE THIS BEFORE DEPLOYING. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
# 24 hours = 1440 minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Database ----
# Default resolves to <project_root>/token_optimizer.db. Override with an
# absolute path or a non-SQLite URL (postgresql+psycopg://… etc).
# DATABASE_URL=sqlite:////absolute/path/to/token_optimizer.db

# ---- Ollama (local by default; point at a remote host if you run Ollama elsewhere) ----
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_TIMEOUT=300

# ---- Advanced provider keys (optional; users can also save their own in UI) ----
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus

# ---- Cache ----
CACHE_TYPE=redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ---- Routing thresholds ----
SIMPLE_QUERY_THRESHOLD=100
MEDIUM_QUERY_THRESHOLD=500

# ---- Bypass keywords (comma-separated or JSON array) ----
BYPASS_KEYWORDS=urgent,critical,advanced,direct,llama-direct

# ---- Logging ----
LOG_LEVEL=INFO
