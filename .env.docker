# Adaptora — docker compose environment template.
# Copy to `.env.docker` and edit before running `docker compose up`:
#
#     cp .env.docker.example .env.docker
#
# Compose auto-loads `.env` by default (not `.env.docker`). To use this
# file, pass it explicitly:
#
#     docker compose --env-file .env.docker up --build
#
# Or rename to `.env` if you don't have another `.env` in the directory.

# ─── Local LLM ──────────────────────────────────────────────────────────────
# Override only if you want a different Ollama model than the project default.
# qwen2.5-coder:3b is small (~2 GB), fast, and works well with the agent's
# JSON-output requirements. Bigger options: qwen2.5-coder:7b, llama3.1:8b.
OLLAMA_MODEL=qwen2.5-coder:3b

# ─── Database ───────────────────────────────────────────────────────────────
# Postgres credentials for the `db` service. Change in production.
POSTGRES_USER=tokopt
POSTGRES_PASSWORD=tokopt
POSTGRES_DB=tokopt

# ─── App secret ─────────────────────────────────────────────────────────────
# Used for JWT signing. MUST be changed to something random (32+ bytes) in
# production. The default is fine for local development only.
SECRET_KEY=please-change-me-in-production

# ─── Optional: external search & LLM providers ──────────────────────────────
# The agent falls back to DuckDuckGo if none of these are set. Tavily (free
# tier: 1000 credits/month) returns full-page content rather than snippets
# and dramatically improves doc-extraction quality.
TAVILY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional: cloud LLM keys (only needed if you use the legacy /api/process
# routes against gpt-* / claude-* models; the Dynamic Agent itself uses
# the local Ollama model above).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Ollama hosted web search (separate from the Ollama daemon — sign
# up at https://ollama.com/ to get a key). When set it's the preferred
# search backend.
OLLAMA_API_KEY=

# ─── Optional: host port overrides ──────────────────────────────────────────
# Override to dodge port conflicts with services already on your host.
# APP_PORT=8000
# DB_PORT=5432
# CACHE_PORT=6379
# OLLAMA_PORT=11434

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_HTTPS=true
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
